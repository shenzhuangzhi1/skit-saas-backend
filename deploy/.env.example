# The activation script generates and persists this on first deployment when omitted.
# You may inject a managed value before the first release. Never commit the real key.
SKIT_AD_ENCRYPTION_KEY=

# Dedicated AES-GCM envelope key for advertising credentials and verified callback payloads.
# The activation script generates and persists it on the first backend release when omitted.
SKIT_AD_CREDENTIAL_KEY=
SKIT_AD_CREDENTIAL_KEY_ID=primary

# Dedicated HMAC key for signed advertising-session customData. The activation script generates
# a safe value on first deployment and persists both it and the positive key version in .env.
# Do not reuse either advertising encryption key for this purpose.
SKIT_AD_SESSION_TOKEN_KEY=
SKIT_AD_SESSION_TOKEN_KEY_VERSION=1

# Absolute public backend origin used to issue immutable Taku callback templates. It must end in
# /app-api and cannot contain userinfo, query, or fragment. HTTPS is required before ENFORCED.
SKIT_AD_CALLBACK_PUBLIC_BASE_URL=http://your-public-host/app-api

# Immediate reverse-proxy CIDRs only. The Docker production topology uses 172.16.0.0/12 by
# default; narrow this value if the server assigns a stable subnet. Never add public client CIDRs.
SKIT_TRUSTED_PROXY_CIDRS=172.16.0.0/12

# Optional one-time seed for retained old key ids/versions. Encode a Spring .properties file with
# base64; activation validates it, writes ad-keyring.properties with mode 0600, and never replaces
# an existing different keyring during an ordinary release. Prefer editing the mounted 0600 file
# directly on the server for later controlled rotations.
SKIT_AD_RETAINED_KEYRING_BASE64=

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=skit_saas
MYSQL_PORT=3306
REDIS_PORT=6379
BACKEND_PORT=48080
BACKEND_HEALTH_PATH=/actuator/health
FRONTEND_PORT=80

# Optional framework API encryption. It is disabled by default because no production endpoint uses
# @ApiEncrypt. Enabling it requires a coordinated frontend release and two distinct 32-byte
# AES keys. Browser-visible symmetric keys do not replace HTTPS.
YUDAO_API_ENCRYPT_ENABLED=false
YUDAO_API_ENCRYPT_REQUEST_KEY=
YUDAO_API_ENCRYPT_RESPONSE_KEY=

# Optional source-profile credentials. They are intentionally blank so application-local.yaml,
# application-dev.yaml, and the packaged base configuration contain no literal credentials.
# Set only the profile/integration you are actively using; production runtime does not use the
# LOCAL_* or DEV_* variables.
LOCAL_MYSQL_MASTER_PASSWORD=
LOCAL_MYSQL_SLAVE_PASSWORD=
LOCAL_DATABASE_PASSWORD=
LOCAL_TDENGINE_PASSWORD=
LOCAL_REDIS_PASSWORD=
LOCAL_RABBITMQ_PASSWORD=
LOCAL_SPRING_BOOT_ADMIN_PASSWORD=
LOCAL_WX_MP_SECRET=
LOCAL_WX_MINIAPP_SECRET=
LOCAL_TENCENT_LBS_KEY=
LOCAL_JUSTAUTH_DINGTALK_CLIENT_SECRET=
LOCAL_JUSTAUTH_WECHAT_ENTERPRISE_CLIENT_SECRET=
LOCAL_JUSTAUTH_WECHAT_MINI_PROGRAM_CLIENT_SECRET=
LOCAL_JUSTAUTH_WECHAT_MP_CLIENT_SECRET=
LOCAL_JUSTAUTH_ALIPAY_CLIENT_SECRET=
LOCAL_JUSTAUTH_ALIPAY_PUBLIC_KEY=

DEV_MYSQL_MASTER_PASSWORD=
DEV_MYSQL_SLAVE_PASSWORD=
DEV_REDIS_PASSWORD=
DEV_RABBITMQ_PASSWORD=
DEV_SPRING_BOOT_ADMIN_PASSWORD=
DEV_WX_MP_SECRET=
DEV_WX_MINIAPP_SECRET=
DEV_TENCENT_LBS_KEY=
DEV_JUSTAUTH_DINGTALK_CLIENT_SECRET=
DEV_JUSTAUTH_WECHAT_ENTERPRISE_CLIENT_SECRET=
DEV_JUSTAUTH_WECHAT_MINI_PROGRAM_CLIENT_SECRET=
DEV_JUSTAUTH_WECHAT_MP_CLIENT_SECRET=
DEV_JUSTAUTH_ALIPAY_CLIENT_SECRET=
DEV_JUSTAUTH_ALIPAY_PUBLIC_KEY=
